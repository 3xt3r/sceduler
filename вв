#!/usr/bin/env bash
set -euo pipefail

DEST="${1:-./sources}"
mkdir -p "$DEST"

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
ok=0; skip=0; fail=0

clone() {
    local name="$1" url="$2"
    local dir="$DEST/$name"
    if [ -d "$dir/.git" ]; then
        echo -e "${YELLOW}[SKIP]${NC} $name — already cloned"
        ((skip++)) || true
    else
        echo -e "${GREEN}[GIT ]${NC} $name  <- $url"
        if git clone --depth=1 "$url" "$dir" 2>/dev/null; then
            ((ok++)) || true
        else
            echo -e "${RED}[FAIL]${NC} $name"
            ((fail++)) || true
        fi
    fi
}

clone "uchardet"     "https://github.com/BYVoid/uchardet.git"
clone "nspr"         "https://github.com/mozilla/nspr.git"
clone "cityhash"     "https://github.com/google/cityhash.git"
clone "zlib-minizip" "https://github.com/madler/zlib.git"
clone "mongoose"     "https://github.com/cesanta/mongoose.git"
clone "nlohmann-json" "https://github.com/nlohmann/json.git"
clone "blake2"       "https://github.com/BLAKE2/BLAKE2.git"
clone "unrar"        "https://github.com/aawc/unrar.git"

echo ""
echo -e "Done: ${GREEN}ok=$ok${NC}  ${YELLOW}skip=$skip${NC}  ${RED}fail=$fail${NC}"
echo "Output: $DEST"
echo ""
echo "NOTE: unrar — официальный RARLAB закрыт, использован форк aawc/unrar."
echo "      Оригинал: https://www.rarlab.com/rar_add.htm"
echo "      minizip лежит в contrib/minizip/ внутри zlib-minizip/"
