def collect_include_occurrences(project_dirs: list[str]) -> list[dict]:
    """
    Возвращает список occurrence, а не только уникальные include.
    Это нужно, чтобы понимать source context:
      - кто подключает;
      - в какой строке;
      - third-party это source file или internal.
    """
    occurrences: list[dict] = []

    for project_dir in project_dirs:
        if not os.path.isdir(project_dir):
            print(f"  Предупреждение: директория не найдена: {project_dir}")
            continue

        for root, dirs, files in os.walk(project_dir):
            dirs[:] = [d for d in dirs if d.lower() not in EXCLUDE_DIRS]
            for filename in files:
                if os.path.splitext(filename)[1].lower() not in SOURCE_EXTS:
                    continue

                filepath = abs_norm(os.path.join(root, filename))
                try:
                    with open(filepath, encoding="utf-8", errors="ignore") as f:
                        for line_no, line in enumerate(f, start=1):
                            m = INCLUDE_RE.match(line)
                            if not m:
                                continue

                            if m.group(1):
                                name, syntax = m.group(2).strip(), "angle"
                            else:
                                name, syntax = m.group(4).strip(), "quote"

                            occurrences.append({
                                "include": name,
                                "syntax": syntax,
                                "source_path": filepath,
                                "line": line_no,
                            })
                except Exception as exc:
                    print(f"  Предупреждение: не удалось прочитать {filepath}: {exc}")
                    continue

    return occurrences


def build_scancode_index(scan_json: str) -> dict[str, list[dict]]:
    """
    Индексируем каждый scancode path по всем суффиксам.

    Пример:
      third_party/zlib/zlib.h
    будет доступен по ключам:
      third_party/zlib/zlib.h
      zlib/zlib.h
      zlib.h

    Это лучше, чем сравнение только по basename, но всё равно остаётся эвристикой.
    """
    with open(scan_json, encoding="utf-8") as f:
        data = json.load(f)

    index: dict[str, list[dict]] = defaultdict(list)
    for entry in data.get("files", []):
        if entry.get("type") != "file":
            continue

        path = norm_key(entry.get("path", ""))
        if not path:
            continue

        entry["_norm_path"] = path
        parts = path.split("/")
        for i in range(len(parts)):
            key = "/".join(parts[i:])
            index[key].append(entry)

    return index


def find_best_in_index(query_path: str, index: dict[str, list[dict]]) -> tuple[list[dict], str]:
    """
    Ищет query_path в scancode index по максимально точному суффиксу.
    Возвращает (entries, matched_key).
    """
    normalized = norm_key(query_path)
    if not normalized:
        return [], ""

    parts = [p for p in normalized.split("/") if p and p != "."]
    candidate_keys = []

    # Полный путь/suffix сначала.
    candidate_keys.append("/".join(parts))

    # Затем все суффиксы от длинного к короткому.
    for i in range(len(parts)):
        candidate_keys.append("/".join(parts[i:]))

    # И только в самом конце basename.
    if parts:
        candidate_keys.append(parts[-1])

    seen = set()
    for key in candidate_keys:
        if not key or key in seen:
            continue
        seen.add(key)
        if key in index:
            return index[key], key

    return [], ""


def has_third_party_metadata(entries: list[dict]) -> bool:
    for entry in entries:
        if entry.get("detected_license_expression"):
            return True
        if entry.get("detected_license_expression_spdx"):
            return True
        if entry.get("copyrights"):
            return True
        if entry.get("holders"):
            return True
    return False


def extract_metadata(entries: list[dict]) -> dict:
    licenses, licenses_spdx, copyrights, holders = set(), set(), set(), set()
    found_paths = set()

    for entry in entries:
        if entry.get("detected_license_expression"):
            licenses.add(entry["detected_license_expression"])
        if entry.get("detected_license_expression_spdx"):
            licenses_spdx.add(entry["detected_license_expression_spdx"])
        for c in entry.get("copyrights", []):
            if c.get("copyright"):
                copyrights.add(c["copyright"])
        for h in entry.get("holders", []):
            if h.get("holder"):
                holders.add(h["holder"])
        if entry.get("path"):
            found_paths.add(entry["path"])

    return {
        "license":      " | ".join(sorted(licenses)),
        "license_spdx": " | ".join(sorted(licenses_spdx)),
        "copyright":    " | ".join(sorted(copyrights)),
        "holders":      " | ".join(sorted(holders)),
        "found_paths":  " | ".join(sorted(found_paths)),
    }


def classify_source_file(source_path: str, index: dict[str, list[dict]]) -> dict:
    """
    Определяет тип source file, где встретился include.
    Это нужно для transitive логики.
    """
    entries, matched_key = find_best_in_index(source_path, index)
    meta = extract_metadata(entries) if entries else {
        "license": "", "license_spdx": "", "copyright": "", "holders": "", "found_paths": ""
    }

    if entries and has_third_party_metadata(entries):
        kind = "Third_Party"
    elif has_vendor_hint(source_path):
        # Не основной источник истины, а safety net: часто ScanCode не находит license
        # в каждом внутреннем header third-party библиотеки.
        kind = "Third_Party_Path_Hint"
    elif entries:
        kind = "Internal"
    else:
        kind = "Unknown_Source"

    return {
        "source_kind": kind,
        "source_scancode_match": matched_key,
        "source_scancode_path": meta["found_paths"],
        "source_license": meta["license"],
        "source_license_spdx": meta["license_spdx"],
        "source_holders": meta["holders"],
    }


