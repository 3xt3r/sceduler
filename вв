def _split_compile_command(entry: dict) -> list[str]:
    if isinstance(entry.get("arguments"), list):
        return [str(a) for a in entry["arguments"]]

    command = entry.get("command") or ""
    if not command:
        return []

    try:
        return shlex.split(command)
    except ValueError:
        return command.split()


def _make_abs_include_path(path: str, base_dir: str) -> str:
    path = os.path.expanduser(os.path.expandvars(path.strip()))
    if not path:
        return ""
    if not os.path.isabs(path):
        path = os.path.join(base_dir, path)
    return abs_norm(path)


def extract_include_paths_from_args(args: list[str], base_dir: str) -> list[str]:
    include_paths: list[str] = []
    i = 0

    while i < len(args):
        arg = args[i]

        # GCC/Clang: -I path, -Ipath
        if arg == "-I" and i + 1 < len(args):
            include_paths.append(_make_abs_include_path(args[i + 1], base_dir))
            i += 2
            continue
        if arg.startswith("-I") and len(arg) > 2:
            include_paths.append(_make_abs_include_path(arg[2:], base_dir))
            i += 1
            continue

        # GCC/Clang: -isystem path, -iquote path, -idirafter path
        if arg in {"-isystem", "-iquote", "-idirafter"} and i + 1 < len(args):
            include_paths.append(_make_abs_include_path(args[i + 1], base_dir))
            i += 2
            continue

        # MSVC-like: /Ipath or /I path
        if arg == "/I" and i + 1 < len(args):
            include_paths.append(_make_abs_include_path(args[i + 1], base_dir))
            i += 2
            continue
        if arg.startswith("/I") and len(arg) > 2:
            include_paths.append(_make_abs_include_path(arg[2:], base_dir))
            i += 1
            continue

        i += 1

    return dedupe_keep_order([p for p in include_paths if p])


def load_compile_commands(path: str | None) -> dict:
    result = {
        "by_file": defaultdict(list),
        "all_include_paths": [],
    }

    if not path:
        return result
    if not os.path.isfile(path):
        print(f"  Предупреждение: compile_commands.json не найден: {path}")
        return result

    try:
        with open(path, encoding="utf-8") as f:
            data = json.load(f)
    except Exception as exc:
        print(f"  Предупреждение: не удалось прочитать compile_commands.json: {exc}")
        return result

    all_paths: list[str] = []
    for entry in data:
        directory = abs_norm(entry.get("directory") or os.getcwd())
        source_file = entry.get("file") or ""
        if source_file and not os.path.isabs(source_file):
            source_file = os.path.join(directory, source_file)
        source_file = abs_norm(source_file) if source_file else ""

        args = _split_compile_command(entry)
        include_paths = extract_include_paths_from_args(args, directory)

        if source_file:
            result["by_file"][source_file].extend(include_paths)
        all_paths.extend(include_paths)

    for file_path, paths in result["by_file"].items():
        result["by_file"][file_path] = dedupe_keep_order(paths)
    result["all_include_paths"] = dedupe_keep_order(all_paths)

    return result


def build_include_context(args) -> dict:
    compile_ctx = load_compile_commands(args.compile_commands)

    cli_paths = []
    for p in args.include_paths or []:
        cli_paths.append(_make_abs_include_path(p, os.getcwd()))

    return {
        "by_file": compile_ctx["by_file"],
        "all_include_paths": compile_ctx["all_include_paths"],
        "cli_include_paths": dedupe_keep_order(cli_paths),
    }


def guess_header_origin(resolved_path: str, project_roots: list[str]) -> str:
    if not resolved_path:
        return "Not found with available include context"

    p = abs_norm(resolved_path)
    parts = path_parts(p)

    if has_generated_hint(p):
        return "Generated/build artifact"

    for root in project_roots:
        if is_under(p, root):
            return "Project tree header"

    if p.startswith("/usr/include/") or "/usr/include/" in p:
        return "OS/system package header"
    if p.startswith("/usr/local/include/") or "/usr/local/include/" in p:
        return "Local system install header"
    if "vcpkg" in parts:
        return "vcpkg package header"
    if "conan" in parts or ".conan" in parts or ".conan2" in parts:
        return "Conan package header"
    if p.startswith("/opt/") or "/sdk/" in p.lower() or "sdk" in parts:
        return "External SDK/header"

    return "External include path header"


def source_specific_include_paths(source_path: str, ctx: dict) -> list[str]:
    source_path = abs_norm(source_path)
    exact = ctx["by_file"].get(source_path, [])
    if exact:
        return exact

    # fallback: если пути отличаются префиксом, пробуем suffix match по compile_commands.
    # Это полезно, когда project path отличается между ScanCode/container/CI.
    source_suffix = "/".join(norm_key(source_path).split("/")[-3:])
    for known_file, paths in ctx["by_file"].items():
        if norm_key(known_file).endswith(source_suffix):
            return paths

    return []


def resolve_header(occurrence: dict, ctx: dict, project_roots: list[str]) -> dict:
    """
    Пытается физически найти header для include.
    Для quote include сначала ищет рядом с source file, потом include paths.
    Для angle include source directory не используется.
    """
    include_name = occurrence["include"]
    syntax = occurrence["syntax"]
    source_path = occurrence["source_path"]

    search_dirs: list[str] = []
    if syntax == "quote":
        search_dirs.append(os.path.dirname(source_path))

    search_dirs.extend(source_specific_include_paths(source_path, ctx))
    search_dirs.extend(ctx.get("cli_include_paths", []))
    search_dirs.extend(ctx.get("all_include_paths", []))
    search_dirs = dedupe_keep_order(search_dirs)

    for base_dir in search_dirs:
        candidate = abs_norm(os.path.join(base_dir, include_name))
        if os.path.isfile(candidate):
            return {
                "resolved_path": candidate,
                "resolved_via": base_dir,
                "header_origin": guess_header_origin(candidate, project_roots),
            }

    return {
        "resolved_path": "",
        "resolved_via": "",
        "header_origin": "Not found with available include context",
    }


def find_target_header_entries(occurrence: dict, resolution: dict, index: dict[str, list[dict]]) -> tuple[list[dict], str]:
    # Сначала пробуем resolved path — он точнее include string.
    if resolution.get("resolved_path"):
        entries, matched_key = find_best_in_index(resolution["resolved_path"], index)
        if entries:
            return entries, matched_key

    # Потом fallback по самому include name.
    return find_best_in_index(occurrence["include"], index)


def source_ref(occurrence: dict) -> str:
    return f"{occurrence['source_path']}:{occurrence['line']}"


def aggregate_rows(rows: list[dict]) -> list[dict]:
    """
    Схлопывает occurrence-level rows в более компактные строки отчёта.
    Источники собираются в одно поле source_refs.
    """
    key_fields = [
        "include", "syntax", "category", "found_paths", "license", "license_spdx",
        "copyright", "holders", "resolved_path", "resolved_via", "header_origin",
        "transitive_type", "source_kind",
    ]

    grouped: dict[tuple, dict] = {}
    for row in rows:
        key = tuple(row.get(k, "") for k in key_fields)
        if key not in grouped:
            grouped[key] = dict(row)
            grouped[key]["source_refs_set"] = set()
            grouped[key]["source_files_set"] = set()
        grouped[key]["source_refs_set"].add(row.get("source_ref", ""))
        grouped[key]["source_files_set"].add(row.get("source_path", ""))

    result = []
    for row in grouped.values():
        row["source_refs"] = " | ".join(sorted(x for x in row.pop("source_refs_set") if x))
        row["source_files"] = " | ".join(sorted(x for x in row.pop("source_files_set") if x))
        result.append(row)

    result.sort(key=lambda r: (r.get("include", ""), r.get("source_kind", ""), r.get("source_refs", "")))
    return result


def classify(occurrences: list[dict], index: dict[str, list[dict]], ctx: dict, project_roots: list[str]):
    system_rows, internal_rows, third_party_rows, unresolved_rows, transitive_rows = [], [], [], [], []

    for occ in sorted(occurrences, key=lambda x: (x["include"], x["source_path"], x["line"])):
        inc = occ["include"]
        syntax = occ["syntax"]
        source_info = classify_source_file(occ["source_path"], index)
        source_is_third_party = source_info["source_kind"].startswith("Third_Party")

        base = {
            "include": inc,
            "syntax": "<...>" if syntax == "angle" else '"..."',
            "source_ref": source_ref(occ),
            "source_path": occ["source_path"],
            "source_kind": source_info["source_kind"],
            "source_scancode_path": source_info["source_scancode_path"],
            "found_paths": "",
            "license": "",
            "license_spdx": "",
            "copyright": "",
            "holders": "",
            "resolved_path": "",
            "resolved_via": "",
            "header_origin": "",
            "transitive_type": "",
            "note": "",
        }

        if syntax == "angle":
            if source_is_third_party:
                row = dict(base)
                row["category"] = "Transitive"
                row["transitive_type"] = "External angle include from third-party source"
                row["header_origin"] = "External/system include path; exact path requires compiler include context"
                transitive_rows.append(row)
            else:
                row = dict(base)
                row["category"] = "System"
                row["header_origin"] = "External/system include path"
                system_rows.append(row)
            continue

        # quote include: пытаемся понять target header и его origin.
        resolution = resolve_header(occ, ctx, project_roots)
        target_entries, matched_key = find_target_header_entries(occ, resolution, index)
        meta = extract_metadata(target_entries) if target_entries else {
            "license": "", "license_spdx": "", "copyright": "", "holders": "", "found_paths": ""
        }

        row = dict(base)
        row.update(meta)
        row["resolved_path"] = resolution["resolved_path"]
        row["resolved_via"] = resolution["resolved_via"]
        row["header_origin"] = resolution["header_origin"]

        if target_entries and has_third_party_metadata(target_entries):
            if source_is_third_party:
                row["category"] = "Transitive"
                row["transitive_type"] = "Quoted include from third-party source to third-party target"
                transitive_rows.append(row)
            else:
                row["category"] = "Third_Party"
                third_party_rows.append(row)
            continue

        if target_entries:
            if source_is_third_party:
                row["category"] = "Transitive"
                row["transitive_type"] = "Vendor-internal quoted include from third-party source"
                row["note"] = "Target has no own license/copyright, but source file is third-party"
                transitive_rows.append(row)
            else:
                row["category"] = "Internal"
                internal_rows.append(row)
            continue

        # Не нашли target в ScanCode.
        if source_is_third_party:
            row["category"] = "Transitive"
            row["transitive_type"] = "Unresolved quoted include from third-party source"
            row["note"] = "Target not found in ScanCode; see resolved_path/header_origin"
            transitive_rows.append(row)
        else:
            row["category"] = "Unresolved"
            row["note"] = "Target not found in ScanCode; see resolved_path/header_origin"
            unresolved_rows.append(row)

    return (
        aggregate_rows(system_rows),
        aggregate_rows(internal_rows),
        aggregate_rows(third_party_rows),
        aggregate_rows(unresolved_rows),
        aggregate_rows(transitive_rows),
    )


