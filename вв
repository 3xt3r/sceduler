SOURCE_EXTS = {".c", ".cc", ".cpp", ".cxx", ".h", ".hh", ".hpp", ".hxx"}

EXCLUDE_DIRS = {
    "test", "tests", "example", "examples", "doc", "docs",
    ".git", ".github", "benchmark", "benchmarks", "build", "dist",
    "__pycache__", ".cache",
}

VENDOR_DIR_HINTS = {
    "third_party", "third-party", "3rdparty", "3rd_party", "vendor",
    "vendors", "external", "extern", "deps", "dependencies",
}

GENERATED_DIR_HINTS = {
    "build", "cmake-build-debug", "cmake-build-release", "generated", "gen", "autogen",
}

INCLUDE_RE = re.compile(
    r'^\s*#\s*include\s*(<)([^>]+)>|^\s*#\s*include\s*(")([^"]+)"'
)

# .so константы
SO_SKIP_DIRS = {
    "/proc", "/sys", "/dev", "/run", "/tmp",
    "/var/run", "/var/lock",
}

SO_FILENAME_RE = re.compile(
    r'^lib([A-Za-z0-9_+\-\.]+?)(?:\.so)(?:\.(\d[\d.]*))?$'
)

VERSION_RE = re.compile(r'\b(\d+\.\d+[\.\d]*)\b')

VERSION_HINT_RE = re.compile(
    r'(version|ver|release|v\d|poco|openssl|zlib|boost|curl|ssl|crypto'
    r'|libpng|libjpeg|libxml|protobuf|grpc|zmq|pcap|pthread)',
    re.IGNORECASE,
)


