def main():
    parser = argparse.ArgumentParser(
        description="Классифицирует #include и опционально генерирует SBoM по .so файлам.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    # --- #include классификация ---
    parser.add_argument(
        "--project",
        required=True,
        action="append",
        dest="projects",
        metavar="DIR",
        help="Путь к исходникам проекта (можно указать несколько раз)",
    )
    parser.add_argument(
        "--scanjson",
        required=True,
        help="Путь к scancode JSON (scancode --copyright --license --json-pp output.json)",
    )
    parser.add_argument(
        "--output",
        default="include_classification.xlsx",
        help="Выходной xlsx (по умолчанию: include_classification.xlsx)",
    )
    parser.add_argument(
        "--compile-commands",
        default=None,
        help="Путь к compile_commands.json. Нужен для точного resolved_path/origin unresolved headers.",
    )
    parser.add_argument(
        "--include-path",
        action="append",
        dest="include_paths",
        metavar="DIR",
        help="Дополнительный include path для резолвинга headers. Можно указать несколько раз.",
    )

    # --- .so SBoM ---
    parser.add_argument(
        "--so",
        action="append",
        dest="so_roots",
        metavar="DIR",
        help="Директория для поиска .so файлов (можно указать несколько раз). "
             "Например: --so /usr/local/lib --so /usr/lib",
    )
    parser.add_argument(
        "--so-output",
        default="sbom_so.cdx.json",
        help="Выходной CycloneDX JSON для .so (по умолчанию: sbom_so.cdx.json)",
    )
    parser.add_argument(
        "--so-no-strings",
        action="store_true",
        help="Не запускать strings при сборе .so (быстрее, версия только из имени файла)",
    )

    args = parser.parse_args()
    project_roots = [abs_norm(p) for p in args.projects]

    # ── Классификация #include ──────────────────
    print("=" * 60)
    print("Шаг 1: сбор #include из исходников")
    print("=" * 60)
    for p in args.projects:
        print(f"  → {p}")

    occurrences = collect_include_occurrences(args.projects)
    unique_includes = {o["include"] for o in occurrences}
    angle = sum(1 for o in occurrences if o["syntax"] == "angle")
    quote = sum(1 for o in occurrences if o["syntax"] == "quote")
    print(f"  Всего occurrences: {len(occurrences)}")
    print(f"  Уникальных include: {len(unique_includes)}")
    print(f"  angle occurrences: {angle}")
    print(f"  quote occurrences: {quote}")

    print("\nШаг 2: загрузка scancode JSON...")
    index = build_scancode_index(args.scanjson)
    print(f"  Проиндексировано scancode-суффиксов: {len(index)}")

    print("\nШаг 3: загрузка include context...")
    ctx = build_include_context(args)
    per_file_count = len(ctx["by_file"])
    all_paths_count = len(ctx["all_include_paths"])
    cli_paths_count = len(ctx["cli_include_paths"])
    print(f"  compile_commands source files: {per_file_count}")
    print(f"  include paths from compile_commands: {all_paths_count}")
    print(f"  include paths from CLI: {cli_paths_count}")

    print("\nШаг 4: классификация...")
    system, internal, third_party, unresolved, transitive = classify(occurrences, index, ctx, project_roots)
    print(f"  System:      {len(system)}")
    print(f"  Internal:    {len(internal)}")
    print(f"  Third_Party: {len(third_party)}")
    print(f"  Transitive:  {len(transitive)}")
    print(f"  Unresolved:  {len(unresolved)}")

    print(f"\nСохранение xlsx → {args.output}")
    build_xlsx(system, internal, third_party, unresolved, transitive, args.output)
    print("  Готово.")

    # ── SBoM по .so ────────────────────────────
    if args.so_roots:
        print("\n" + "=" * 60)
        print("Шаг 5: сбор .so файлов")
        print("=" * 60)
        for r in args.so_roots:
            print(f"  → {r}")

        so_files = find_so_files(args.so_roots)
        print(f"  Найдено .so файлов: {len(so_files)}")

        print("\nШаг 6: извлечение метаданных из .so...")
        components = build_so_components(so_files, args.so_no_strings)

        unknown = sum(1 for c in components if c["version"] == "unknown")
        print(f"  Уникальных библиотек: {len(components)}")
        print(f"  Версия неизвестна:    {unknown}")

        sbom = build_cyclonedx_sbom(components, args.so_roots)
        with open(args.so_output, "w", encoding="utf-8") as f:
            json.dump(sbom, f, indent=2, ensure_ascii=False)
        print(f"\nSBoM сохранён → {args.so_output}")


if __name__ == "__main__":
    main()
