#!/usr/bin/env python3
"""
sca_classify.py — классификация #include директив + опциональный SBoM по .so файлам.

Логика классификации #include:
  #include <...>  → System     (угловые скобки — внешний заголовок)
  #include "..."  + найден в scancode + есть copyright/license → Third_Party
  #include "..."  + найден в scancode + нет copyright/license  → Internal
  #include "..."  + не найден в scancode                       → Unresolved

Выходные файлы:
  include_classification.xlsx  — классификация заголовков (всегда)
  sbom_so.cdx.json             — CycloneDX SBoM по .so файлам (если указан --so)

Запуск:
  # Один проект
  python3 sca_classify.py --project /src --scanjson output.json

  # Несколько проектов
  python3 sca_classify.py \\
      --project /src/test_libs \\
      --project /src/test_libs_help \\
      --scanjson output.json

  # С генерацией SBoM по .so
  python3 sca_classify.py \\
      --project /src \\
      --scanjson output.json \\
      --so /usr/local/lib \\
      --so /usr/lib \\
      --so-output sbom_so.cdx.json
"""

import hashlib
import json
import os
import re
import argparse
import subprocess
import uuid
from collections import defaultdict
from datetime import datetime, timezone

import openpyxl
from openpyxl.styles import Font, PatternFill, Alignment
from openpyxl.utils import get_column_letter

# ─────────────────────────────────────────────
# Константы
# ─────────────────────────────────────────────

SOURCE_EXTS = {".c", ".cc", ".cpp", ".cxx", ".h", ".hh", ".hpp", ".hxx"}

EXCLUDE_DIRS = {
    "test", "tests", "example", "examples", "doc", "docs",
    ".git", ".github", "benchmark", "benchmarks", "build", "dist",
    "__pycache__", ".cache",
}

INCLUDE_RE = re.compile(
    r'^\s*#\s*include\s*(<)([^>]+)>|^\s*#\s*include\s*(")([^"]+)"'
)

# .so константы
SO_SKIP_DIRS = {
    "/proc", "/sys", "/dev", "/run", "/tmp",
    "/var/run", "/var/lock",
}

SO_FILENAME_RE = re.compile(
    r'^lib([A-Za-z0-9_+\-\.]+?)(?:\.so)(?:\.(\d[\d.]*))?$'
)

VERSION_RE = re.compile(r'\b(\d+\.\d+[\.\d]*)\b')

VERSION_HINT_RE = re.compile(
    r'(version|ver|release|v\d|poco|openssl|zlib|boost|curl|ssl|crypto'
    r'|libpng|libjpeg|libxml|protobuf|grpc|zmq|pcap|pthread)',
    re.IGNORECASE
)


# ═════════════════════════════════════════════
# ЧАСТЬ 1: классификация #include
# ═════════════════════════════════════════════

def collect_includes(project_dirs: list[str]) -> dict[str, dict]:
    """
    Возвращает dict: include_name → {"syntax": "angle"|"quote", "sources": set(filepaths)}.
    angle побеждает quote — если хоть раз встречается <...>,
    заголовок считается внешним.
    sources — множество файлов где встречается этот #include.
    """
    includes: dict[str, dict] = {}
    for project_dir in project_dirs:
        if not os.path.isdir(project_dir):
            print(f"  Предупреждение: директория не найдена: {project_dir}")
            continue
        for root, dirs, files in os.walk(project_dir):
            dirs[:] = [d for d in dirs if d.lower() not in EXCLUDE_DIRS]
            for filename in files:
                if os.path.splitext(filename)[1].lower() not in SOURCE_EXTS:
                    continue
                filepath = os.path.join(root, filename)
                try:
                    with open(filepath, encoding="utf-8", errors="ignore") as f:
                        for line in f:
                            m = INCLUDE_RE.match(line)
                            if not m:
                                continue
                            if m.group(1):
                                name, syntax = m.group(2), "angle"
                            else:
                                name, syntax = m.group(4), "quote"
                            if name not in includes:
                                includes[name] = {"syntax": syntax, "sources": set()}
                            elif syntax == "angle":
                                includes[name]["syntax"] = "angle"
                            includes[name]["sources"].add(filepath)
                except Exception:
                    continue
    return includes


def build_scancode_index(scan_json: str) -> dict[str, list[dict]]:
    with open(scan_json, encoding="utf-8") as f:
        data = json.load(f)

    index: dict[str, list[dict]] = defaultdict(list)
    for entry in data.get("files", []):
        if entry.get("type") != "file":
            continue
        path = entry.get("path", "").replace("\\", "/")
        if not path:
            continue
        parts = path.split("/")
        for i in range(len(parts)):
            index["/".join(parts[i:])].append(entry)
    return index


def find_in_index(include_name: str, index: dict[str, list[dict]]) -> list[dict]:
    normalized = include_name.replace("\\", "/")
    if normalized in index:
        return index[normalized]
    basename = normalized.split("/")[-1]
    if basename in index:
        return index[basename]
    return []


def extract_metadata(entries: list[dict]) -> dict:
    licenses, licenses_spdx, copyrights, holders = set(), set(), set(), set()
    for entry in entries:
        if entry.get("detected_license_expression"):
            licenses.add(entry["detected_license_expression"])
        if entry.get("detected_license_expression_spdx"):
            licenses_spdx.add(entry["detected_license_expression_spdx"])
        for c in entry.get("copyrights", []):
            if c.get("copyright"):
                copyrights.add(c["copyright"])
        for h in entry.get("holders", []):
            if h.get("holder"):
                holders.add(h["holder"])
    return {
        "license":      " | ".join(sorted(licenses)),
        "license_spdx": " | ".join(sorted(licenses_spdx)),
        "copyright":    " | ".join(sorted(copyrights)),
        "holders":      " | ".join(sorted(holders)),
        "found_paths":  " | ".join(sorted({e["path"] for e in entries})),
    }


def classify(includes: dict[str, dict], index: dict[str, list[dict]]):
    system, internal, third_party, unresolved = [], [], [], []

    # Сначала определяем какие файлы являются third-party
    # (те файлы из scancode у которых есть copyright/license)
    third_party_paths: set[str] = set()
    for entry_list in index.values():
        for entry in entry_list:
            licenses = entry.get("detected_license_expression") or ""
            copyrights = entry.get("copyrights", [])
            holders = entry.get("holders", [])
            if licenses or copyrights or holders:
                third_party_paths.add(entry["path"].replace("\\", "/"))

    for inc, info in sorted(includes.items()):
        syntax = info["syntax"]
        sources = info["sources"]

        if syntax == "angle":
            # Проверяем: все ли источники этого include — third-party файлы?
            # Нормализуем пути источников для сравнения с путями scancode
            source_basenames = {os.path.basename(s) for s in sources}
            tp_sources = set()
            for tp_path in third_party_paths:
                if os.path.basename(tp_path) in source_basenames:
                    tp_sources.add(tp_path)

            if tp_sources and all(
                os.path.basename(s) in {os.path.basename(tp) for tp in tp_sources}
                for s in sources
            ):
                # Все источники — third-party файлы → транзитивная зависимость
                system.append({
                    "include": inc,
                    "transitive_from": " | ".join(sorted({os.path.basename(tp) for tp in tp_sources})),
                })
            else:
                system.append({"include": inc, "transitive_from": ""})
            continue

        entries = find_in_index(inc, index)
        if not entries:
            unresolved.append({"include": inc})
            continue
        meta = extract_metadata(entries)
        row = {"include": inc, **meta}
        if meta["license"] or meta["copyright"] or meta["holders"]:
            third_party.append(row)
        else:
            internal.append(row)

    # Разделяем system на обычные системные и транзитивные
    transitive = [r for r in system if r.get("transitive_from")]
    system_clean = [r for r in system if not r.get("transitive_from")]

    return system_clean, internal, third_party, unresolved, transitive


# ═════════════════════════════════════════════
# ЧАСТЬ 2: сбор .so и генерация CycloneDX SBoM
# ═════════════════════════════════════════════

def find_so_files(roots: list[str]) -> list[str]:
    result = []
    for root in roots:
        if not os.path.isdir(root):
            print(f"  Предупреждение: директория не найдена: {root}")
            continue
        for dirpath, dirnames, filenames in os.walk(root, followlinks=False):
            dirnames[:] = [
                d for d in dirnames
                if os.path.join(dirpath, d) not in SO_SKIP_DIRS
                and not os.path.join(dirpath, d).startswith(tuple(SO_SKIP_DIRS))
            ]
            for filename in filenames:
                if ".so" not in filename:
                    continue
                filepath = os.path.join(dirpath, filename)
                try:
                    if os.path.isfile(filepath) and not _is_symlink_to_so(filepath):
                        result.append(filepath)
                except (OSError, PermissionError):
                    continue
    return result


def _is_symlink_to_so(filepath: str) -> bool:
    if not os.path.islink(filepath):
        return False
    return ".so" in os.readlink(filepath)


def parse_soname(filename: str) -> tuple[str, str]:
    basename = os.path.basename(filename)
    m = SO_FILENAME_RE.match(basename)
    if m:
        return m.group(1), m.group(2) or ""
    name = basename.split(".so")[0]
    if name.startswith("lib"):
        name = name[3:]
    return name, ""


def extract_version_from_strings(filepath: str, lib_name: str) -> str:
    try:
        result = subprocess.run(
            ["strings", filepath],
            capture_output=True, text=True, timeout=10
        )
        lines = result.stdout.splitlines()
    except (FileNotFoundError, subprocess.TimeoutExpired, OSError):
        return ""

    candidates = []
    for line in lines:
        line = line.strip()
        if not line or len(line) > 120:
            continue
        versions = VERSION_RE.findall(line)
        if not versions:
            continue
        if lib_name.lower() in line.lower():
            candidates.append((0, versions[0]))
        elif VERSION_HINT_RE.search(line):
            candidates.append((1, versions[0]))

    if not candidates:
        return ""
    candidates.sort(key=lambda x: (x[0], -len(x[1])))
    return candidates[0][1]


def sha256_file(filepath: str) -> str:
    h = hashlib.sha256()
    try:
        with open(filepath, "rb") as f:
            for chunk in iter(lambda: f.read(65536), b""):
                h.update(chunk)
        return h.hexdigest()
    except (OSError, PermissionError):
        return ""


def build_so_components(so_files: list[str], no_strings: bool) -> list[dict]:
    components = []
    total = len(so_files)

    for i, filepath in enumerate(sorted(so_files), 1):
        print(f"  [{i}/{total}] {os.path.basename(filepath):<50}", end="\r")

        name, version = parse_soname(filepath)
        if not version and not no_strings:
            version = extract_version_from_strings(filepath, name)

        sha256 = sha256_file(filepath)
        filename = os.path.basename(filepath)
        soname = filename.split(".so")[0] + ".so"

        component = {
            "type": "library",
            "bom-ref": str(uuid.uuid4()),
            "name": soname,
            "version": version if version else "unknown",
            "purl": f"pkg:generic/{name}@{version}" if version else f"pkg:generic/{name}",
            "properties": [
                {"name": "so:path",     "value": os.path.abspath(filepath)},
                {"name": "so:filename", "value": filename},
                {"name": "so:lib_name", "value": name},
            ],
        }
        if sha256:
            component["hashes"] = [{"alg": "SHA-256", "content": sha256}]

        components.append(component)

    print()

    # Дедупликация: приоритет у компонента с версией
    deduped: dict[str, dict] = {}
    for c in components:
        key = c["name"].lower()
        if key not in deduped or (
            deduped[key]["version"] == "unknown" and c["version"] != "unknown"
        ):
            deduped[key] = c

    return list(deduped.values())


def build_cyclonedx_sbom(components: list[dict], so_roots: list[str]) -> dict:
    return {
        "bomFormat": "CycloneDX",
        "specVersion": "1.4",
        "serialNumber": f"urn:uuid:{uuid.uuid4()}",
        "version": 1,
        "metadata": {
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "tools": [{"vendor": "custom", "name": "sca_classify.py", "version": "2.0.0"}],
            "component": {
                "type": "operating-system",
                "name": "container",
                "description": f"Scanned roots: {', '.join(so_roots)}",
            },
        },
        "components": components,
    }


# ═════════════════════════════════════════════
# ЧАСТЬ 3: xlsx отчёт
# ═════════════════════════════════════════════

BODY_FONT = Font(name="Arial", size=10)
ALT_FILL  = PatternFill("solid", start_color="EEF3F8")
CENTER    = Alignment(horizontal="center", vertical="center", wrap_text=True)
LEFT      = Alignment(horizontal="left",   vertical="center", wrap_text=True)

SHEET_COLORS = {
    "System":      "2E75B6",
    "Internal":    "375623",
    "Third_Party": "843C0C",
    "Transitive":  "5C3292",
    "Unresolved":  "7B7B7B",
}

COLUMNS = {
    "System": [
        ("Include directive", 50),
    ],
    "Internal": [
        ("Include directive", 40),
        ("Found at (scancode path)", 55),
    ],
    "Third_Party": [
        ("Include directive", 35),
        ("Found at (scancode path)", 50),
        ("License (scancode)", 30),
        ("License SPDX", 20),
        ("Copyright", 50),
        ("Holders", 40),
    ],
    "Transitive": [
        ("Include directive", 50),
        ("Transitive from (third-party file)", 60),
    ],
    "Unresolved": [
        ("Include directive", 55),
        ("Note", 65),
    ],
}

DATA_KEYS = {
    "System":      ["include"],
    "Internal":    ["include", "found_paths"],
    "Third_Party": ["include", "found_paths", "license", "license_spdx", "copyright", "holders"],
    "Transitive":  ["include", "transitive_from"],
    "Unresolved":  ["include", "note"],
}


def write_sheet(wb: openpyxl.Workbook, sheet_name: str, rows: list[dict]) -> None:
    ws = wb.create_sheet(sheet_name)
    cols = COLUMNS[sheet_name]
    keys = DATA_KEYS[sheet_name]
    accent = SHEET_COLORS[sheet_name]

    for col_idx, (col_name, col_width) in enumerate(cols, start=1):
        cell = ws.cell(row=1, column=col_idx, value=col_name)
        cell.font = Font(bold=True, color="FFFFFF", name="Arial", size=10)
        cell.fill = PatternFill("solid", start_color=accent)
        cell.alignment = CENTER
        ws.column_dimensions[get_column_letter(col_idx)].width = col_width

    ws.row_dimensions[1].height = 22

    for row_idx, row in enumerate(rows, start=2):
        fill = ALT_FILL if row_idx % 2 == 0 else PatternFill("solid", start_color="FFFFFF")
        for col_idx, key in enumerate(keys, start=1):
            cell = ws.cell(row=row_idx, column=col_idx, value=row.get(key, ""))
            cell.font = BODY_FONT
            cell.fill = fill
            cell.alignment = LEFT

    ws.cell(row=len(rows) + 2, column=1, value=f"Total: {len(rows)}").font = Font(
        bold=True, name="Arial", size=10, color=accent
    )
    ws.freeze_panes = "A2"


def build_xlsx(system, internal, third_party, unresolved, transitive, output_path: str) -> None:
    wb = openpyxl.Workbook()
    wb.remove(wb.active)

    for row in unresolved:
        row["note"] = 'Quoted include "..." not found in scancode — check for missing dependency'

    write_sheet(wb, "System", system)
    write_sheet(wb, "Internal", internal)
    write_sheet(wb, "Third_Party", third_party)
    write_sheet(wb, "Transitive", transitive)
    write_sheet(wb, "Unresolved", unresolved)

    ws_s = wb.create_sheet("Summary", 0)
    ws_s.column_dimensions["A"].width = 56
    ws_s.column_dimensions["B"].width = 14

    total = len(system) + len(internal) + len(third_party) + len(transitive) + len(unresolved)
    rows = [
        ("Category", "Count"),
        ("System  (#include <...>, truly external)", len(system)),
        ("Internal  (in project, no copyright)", len(internal)),
        ("Third-party  (in project, has copyright/license)", len(third_party)),
        ("Transitive  (#include <...> from third-party files)", len(transitive)),
        ("Unresolved  (#include \"...\", not found in scancode)", len(unresolved)),
        ("Total", total),
    ]
    accent_map = ["1F4E79", "2E75B6", "375623", "843C0C", "5C3292", "7B7B7B", "1F4E79"]
    for i, (label, count) in enumerate(rows):
        c1 = ws_s.cell(row=i + 1, column=1, value=label)
        c2 = ws_s.cell(row=i + 1, column=2, value=count)
        if i == 0:
            for c in (c1, c2):
                c.font = Font(bold=True, color="FFFFFF", name="Arial", size=10)
                c.fill = PatternFill("solid", start_color="1F4E79")
                c.alignment = CENTER
        else:
            c1.font = Font(bold=(i == len(rows) - 1), name="Arial", size=10)
            c2.font = Font(bold=True, name="Arial", size=10, color=accent_map[i])
            c1.alignment = LEFT
            c2.alignment = CENTER

    ws_s.row_dimensions[1].height = 22
    ws_s.freeze_panes = "A2"
    wb.save(output_path)


# ═════════════════════════════════════════════
# main
# ═════════════════════════════════════════════

def main():
    parser = argparse.ArgumentParser(
        description="Классифицирует #include и опционально генерирует SBoM по .so файлам.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    # --- #include классификация ---
    parser.add_argument(
        "--project",
        required=True,
        action="append",
        dest="projects",
        metavar="DIR",
        help="Путь к исходникам проекта (можно указать несколько раз)",
    )
    parser.add_argument(
        "--scanjson",
        required=True,
        help="Путь к scancode JSON (scancode --copyright --license --json-pp output.json)",
    )
    parser.add_argument(
        "--output",
        default="include_classification.xlsx",
        help="Выходной xlsx (по умолчанию: include_classification.xlsx)",
    )

    # --- .so SBoM ---
    parser.add_argument(
        "--so",
        action="append",
        dest="so_roots",
        metavar="DIR",
        help="Директория для поиска .so файлов (можно указать несколько раз). "
             "Например: --so /usr/local/lib --so /usr/lib",
    )
    parser.add_argument(
        "--so-output",
        default="sbom_so.cdx.json",
        help="Выходной CycloneDX JSON для .so (по умолчанию: sbom_so.cdx.json)",
    )
    parser.add_argument(
        "--so-no-strings",
        action="store_true",
        help="Не запускать strings при сборе .so (быстрее, версия только из имени файла)",
    )

    args = parser.parse_args()

    # ── Классификация #include ──────────────────
    print("=" * 55)
    print("Шаг 1: сбор #include из исходников")
    print("=" * 55)
    for p in args.projects:
        print(f"  → {p}")
    includes = collect_includes(args.projects)
    angle = sum(1 for s in includes.values() if s == "angle")
    quote = sum(1 for s in includes.values() if s == "quote")
    print(f"  Всего уникальных: {len(includes)}  (angle: {angle}, quote: {quote})")

    print("\nШаг 2: загрузка scancode JSON...")
    index = build_scancode_index(args.scanjson)
    print(f"  Проиндексировано суффиксов: {len(index)}")

    print("\nШаг 3: классификация...")
    system, internal, third_party, unresolved, transitive = classify(includes, index)
    print(f"  System:      {len(system)}")
    print(f"  Internal:    {len(internal)}")
    print(f"  Third_Party: {len(third_party)}")
    print(f"  Transitive:  {len(transitive)}")
    print(f"  Unresolved:  {len(unresolved)}")

    print(f"\nСохранение xlsx → {args.output}")
    build_xlsx(system, internal, third_party, unresolved, transitive, args.output)
    print("  Готово.")

    # ── SBoM по .so ────────────────────────────
    if args.so_roots:
        print("\n" + "=" * 55)
        print("Шаг 4: сбор .so файлов")
        print("=" * 55)
        for r in args.so_roots:
            print(f"  → {r}")

        so_files = find_so_files(args.so_roots)
        print(f"  Найдено .so файлов: {len(so_files)}")

        print("\nШаг 5: извлечение метаданных из .so...")
        components = build_so_components(so_files, args.so_no_strings)

        unknown = sum(1 for c in components if c["version"] == "unknown")
        print(f"  Уникальных библиотек: {len(components)}")
        print(f"  Версия неизвестна:    {unknown}")

        sbom = build_cyclonedx_sbom(components, args.so_roots)
        with open(args.so_output, "w", encoding="utf-8") as f:
            json.dump(sbom, f, indent=2, ensure_ascii=False)
        print(f"\nSBoM сохранён → {args.so_output}")


if __name__ == "__main__":
    main()
