def norm_slash(path: str) -> str:
    return path.replace("\\", "/")


def norm_key(path: str) -> str:
    path = norm_slash(path).strip()
    while path.startswith("./"):
        path = path[2:]
    return path.lstrip("/")


def abs_norm(path: str) -> str:
    return norm_slash(os.path.abspath(os.path.expanduser(os.path.expandvars(path))))


def is_under(path: str, root: str) -> bool:
    try:
        return os.path.commonpath([abs_norm(path), abs_norm(root)]) == abs_norm(root)
    except ValueError:
        return False


def dedupe_keep_order(items: list[str]) -> list[str]:
    seen = set()
    result = []
    for item in items:
        if not item:
            continue
        normalized = abs_norm(item) if os.path.isabs(item) else item
        if normalized in seen:
            continue
        seen.add(normalized)
        result.append(item)
    return result


def compact_join(values, limit: int = 80) -> str:
    values = [str(v) for v in values if v]
    if not values:
        return ""
    values = sorted(set(values))
    text = " | ".join(values)
    return text[:limit] + " ..." if len(text) > limit else text


def path_parts(path: str) -> set[str]:
    return {p.lower() for p in norm_slash(path).split("/") if p}


def has_vendor_hint(path: str) -> bool:
    return bool(path_parts(path) & VENDOR_DIR_HINTS)


def has_generated_hint(path: str) -> bool:
    return bool(path_parts(path) & GENERATED_DIR_HINTS)


